pipeline {
    agent any

    environment {
        ACR_NAME = "hubrudcontainerregistry.azurecr.io"
        IMAGE_NAME = "frontend"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Frontend Image') {
            steps {
                dir('services/frontend') {
                    sh '''
                    docker build -t $ACR_NAME/$IMAGE_NAME:latest .
                    '''
                }
            }
        }

        stage('Login to ACR') {
            steps {
                sh '''
                az acr login --name hubrudcontainerregistry
                '''
            }
        }

        stage('Push Image') {
            steps {
                sh '''
                docker push $ACR_NAME/$IMAGE_NAME:latest
                '''
            }
        }

        stage('Generate Ansible Inventory') {
            steps {
                script {

                    env.DEV1_IP = sh(
                        script: "cd terraform/dev-1 && terraform init && terraform output -raw dev1_public_ip",
                        returnStdout: true
                    ).trim()

                    sh """
tee ansible/inventory/hosts.ini <<EOF
[dev1]
${env.DEV1_IP} ansible_user=azureuser ansible_ssh_private_key_file=../keys/demo
EOF
                    """
                }
            }
        }

        stage('Deploy via Ansible') {
            steps {
                dir('ansible') {
                    sh '''
                    ansible-playbook playbooks/dev1-playbook.yml
                    '''
                }
            }
        }

    }
}